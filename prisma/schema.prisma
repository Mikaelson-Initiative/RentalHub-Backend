generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String             @id @default(cuid())
  name                 String
  email                String             @unique
  password             String?
  role                 Role               @default(STUDENT)
  emailVerified        Boolean            @default(false)
  verificationStatus   VerificationStatus @default(UNVERIFIED)
  governmentIdUrl      String?
  selfieUrl            String?
  ownershipProofUrl    String?
  matricCardUrl        String?
  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?
  avatarUrl            String?
  phoneNumber          String?
  phoneVerified        Boolean            @default(false)
  campus               String             @default("bouesti")
  isFrozen             Boolean            @default(false)
  frozenReason         String?
  aiPreScreenScore     String?
  aiPreScreenNote      String?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  matricNumber        String?
  studentIdUrl        String?
  portalScreenshotUrl String?
  strikeCount         Int     @default(0)

  properties              Property[]
  bookings                Booking[]
  emailOtps               EmailOtp[]
  notifications           Notification[]
  reviewsGiven            Review[]       @relation("StudentReviews")
  referralsOwned          Referral[]     @relation("ReferralOwner")
  referralsUsed           Referral[]     @relation("ReferralUser")
  inspectionsAsStudent    Inspection[]   @relation("InspectionStudent")
  inspectionsAsInspector  Inspection[]   @relation("InspectionInspector")

  @@map("users")
}

model EmailOtp {
  id        String    @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_otps")
}

model Location {
  id             String     @id @default(cuid())
  name           String     @unique
  classification String     @default("Neighbourhood")
  lat            Float?
  lng            Float?
  campus         String     @default("bouesti")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  properties     Property[]

  @@map("locations")
}

model Property {
  id               String         @id @default(cuid())
  title            String
  description      String
  price            Decimal        @db.Decimal(10, 2)
  distanceToCampus Decimal?       @db.Decimal(5, 2)
  amenities        Json           @default("[]")
  images           Json           @default("[]")
  status           PropertyStatus @default(PENDING)
  listingStatus    ListingStatus  @default(AVAILABLE)
  vacantUnits      Int            @default(1)
  viewCount        Int            @default(0)
  reviewNote       String?
  aiScamFlag       Boolean        @default(false)
  aiScamReason     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  locationId       String
  landlordId       String
  reviewedById     String?

  location    Location     @relation(fields: [locationId], references: [id])
  landlord    User         @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  reviews     Review[]
  inspections Inspection[]

  @@map("properties")
}

model Booking {
  id                  String        @id @default(cuid())
  status              BookingStatus @default(PENDING)
  payoutStatus        PayoutStatus  @default(PENDING)
  paymentStatus       PaymentStatus @default(PENDING)
  bidAmount           Decimal?      @db.Decimal(10, 2)
  amount              Decimal?      @db.Decimal(10, 2)
  agencyFee           Decimal?      @db.Decimal(10, 2)
  cautionFee          Decimal?      @db.Decimal(10, 2)
  paidAt              DateTime?
  moveInDate          DateTime?
  leaseEndDate        DateTime?
  movedInConfirmedAt  DateTime?
  agreementSignedAt   DateTime?
  agreementSignedName String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  propertyId          String
  studentId           String

  property Property  @relation(fields: [propertyId], references: [id])
  student  User      @relation(fields: [studentId], references: [id])
  payments Payment[]

  @@map("bookings")
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  paystackRef String?       @unique
  channel     String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Review {
  id         String   @id @default(cuid())
  studentId  String
  propertyId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  student    User     @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([studentId, propertyId])
  @@map("reviews")
}

model Referral {
  id         String    @id @default(cuid())
  code       String    @unique
  referrerId String
  usedById   String?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  referrer   User      @relation("ReferralOwner", fields: [referrerId], references: [id], onDelete: Cascade)
  usedBy     User?     @relation("ReferralUser", fields: [usedById], references: [id])

  @@map("referrals")
}

enum Role {
  STUDENT
  LANDLORD
  ADMIN
  MODERATOR
  AUDITOR
  INSPECTOR
}

model Inspection {
  id          String           @id @default(cuid())
  status      InspectionStatus @default(REQUESTED)
  propertyId  String
  studentId   String
  inspectorId String?
  scheduledAt DateTime?
  completedAt DateTime?
  expiresAt   DateTime
  notes       String?
  videoLink   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  student   User     @relation("InspectionStudent",   fields: [studentId],   references: [id], onDelete: Cascade)
  inspector User?    @relation("InspectionInspector", fields: [inspectorId], references: [id])

  @@map("inspections")
}

enum InspectionStatus {
  REQUESTED
  ACCEPTED
  COMPLETED
  EXPIRED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  SUSPENDED
  UNDER_REVIEW
  REJECTED
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  AVAILABLE
  PENDING
  RENTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  AWAITING_PAYMENT
  PAID
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
